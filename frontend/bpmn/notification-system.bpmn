<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://example.com/bpmn">
  <bpmn:process id="NotificationSystemProcess" isExecutable="true">
    <bpmn:startEvent id="StartEvent" name="Open app"/>
    <bpmn:task id="CheckTokenTask" name="Check local token"/>
    <bpmn:exclusiveGateway id="TokenGateway" name="Token present?"/>
    <bpmn:task id="AuthMeTask" name="Call /auth/me"/>
    <bpmn:task id="ShowLoginTask" name="Show login page"/>
    <bpmn:exclusiveGateway id="AuthGateway" name="Auth successful?"/>
    <bpmn:task id="LoginSubmitTask" name="Submit login credentials"/>
    <bpmn:task id="LoginApiTask" name="POST /auth/login"/>
    <bpmn:task id="SaveTokenTask" name="Save token and refreshToken"/>
    <bpmn:task id="ShowErrorTask" name="Show login error"/>
    <bpmn:task id="DashboardTask" name="Load dashboard"/>
    <bpmn:task id="SocketConnectTask" name="Connect Socket.IO"/>
    <bpmn:task id="LoadNotificationsTask" name="GET /notifications"/>
    <bpmn:task id="RenderNotificationsTask" name="Render notifications"/>
    <bpmn:task id="NotificationEventTask" name="Receive new notification event"/>
    <bpmn:task id="MarkReadTask" name="Mark notification as read"/>
    <bpmn:task id="MarkAllReadTask" name="Mark all notifications as read"/>
    <bpmn:endEvent id="EndEvent" name="End"/>
    <bpmn:sequenceFlow id="flow1" sourceRef="StartEvent" targetRef="CheckTokenTask"/>
    <bpmn:sequenceFlow id="flow2" sourceRef="CheckTokenTask" targetRef="TokenGateway"/>
    <bpmn:sequenceFlow id="flow3" sourceRef="TokenGateway" targetRef="AuthMeTask" name="Yes"/>
    <bpmn:sequenceFlow id="flow4" sourceRef="TokenGateway" targetRef="ShowLoginTask" name="No"/>
    <bpmn:sequenceFlow id="flow5" sourceRef="AuthMeTask" targetRef="AuthGateway"/>
    <bpmn:sequenceFlow id="flow6" sourceRef="AuthGateway" targetRef="DashboardTask" name="Yes"/>
    <bpmn:sequenceFlow id="flow7" sourceRef="AuthGateway" targetRef="ShowLoginTask" name="No"/>
    <bpmn:sequenceFlow id="flow8" sourceRef="ShowLoginTask" targetRef="LoginSubmitTask"/>
    <bpmn:sequenceFlow id="flow9" sourceRef="LoginSubmitTask" targetRef="LoginApiTask"/>
    <bpmn:sequenceFlow id="flow10" sourceRef="LoginApiTask" targetRef="SaveTokenTask"/>
    <bpmn:sequenceFlow id="flow11" sourceRef="SaveTokenTask" targetRef="DashboardTask"/>
    <bpmn:sequenceFlow id="flow12" sourceRef="ShowLoginTask" targetRef="EndEvent" name="User exits"/>
    <bpmn:sequenceFlow id="flow13" sourceRef="DashboardTask" targetRef="SocketConnectTask"/>
    <bpmn:sequenceFlow id="flow14" sourceRef="SocketConnectTask" targetRef="LoadNotificationsTask"/>
    <bpmn:sequenceFlow id="flow15" sourceRef="LoadNotificationsTask" targetRef="RenderNotificationsTask"/>
    <bpmn:sequenceFlow id="flow16" sourceRef="RenderNotificationsTask" targetRef="NotificationEventTask"/>
    <bpmn:sequenceFlow id="flow17" sourceRef="NotificationEventTask" targetRef="RenderNotificationsTask"/>
    <bpmn:sequenceFlow id="flow18" sourceRef="RenderNotificationsTask" targetRef="MarkReadTask"/>
    <bpmn:sequenceFlow id="flow19" sourceRef="RenderNotificationsTask" targetRef="MarkAllReadTask"/>
    <bpmn:sequenceFlow id="flow20" sourceRef="MarkReadTask" targetRef="EndEvent"/>
    <bpmn:sequenceFlow id="flow21" sourceRef="MarkAllReadTask" targetRef="EndEvent"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="NotificationSystemProcess"/>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
